File downloads and uploads need one concrete file target. The parser accepts
direct paths, copy links, shared links, and [[Doc2.aspx]] file-id links, but
it rejects folders and site roots because those would hide genuine mistakes.
<<functions>>=
def parse_sharepoint_url(url: str) -> SharePointLocation:
  """Resolve a SharePoint URL or server-relative path to REST coordinates."""
  url = _resolve_sharepoint_url(url)
  parsed = urllib.parse.urlsplit(url)
  if not parsed.scheme or not parsed.netloc:
    raise ValueError(f"Unsupported OneDrive URL: {url}")

  site_path, server_relative_path, file_id = _extract_file_reference(parsed)
  if server_relative_path is not None and server_relative_path.endswith("/"):
    raise ValueError("The URL must address one file, not a folder.")
  if _is_site_root_path(server_relative_path):
    raise ValueError("The URL must address one file, not a site root.")

  return SharePointLocation(
      site_url=_build_site_url(parsed, site_path),
      server_relative_path=server_relative_path,
      file_id=file_id)
@

We first normalise the path part of the browser URL. Copy links add an extra
marker segment that should not reach the REST API, while library views and
folder copy links should fail fast when a file operation tries to use them.
<<functions>>=
def _extract_server_relative_path(path: str) -> str:
  """Return the server-relative file path embedded in ``path``."""
  decoded_path = urllib.parse.unquote(path)
  stripped_path = _strip_copy_link_prefix(decoded_path)
  if stripped_path.lower().endswith(ALL_ITEMS_PATH_SUFFIX.lower()):
    raise ValueError(
        "AllItems.aspx URLs address folders. Use a folder command or a "
        "direct file URL instead.")
  if FOLDER_COPY_LINK_RE.match(decoded_path):
    raise ValueError("Folder copy links do not address one file.")
  if stripped_path.lower().endswith("/doc.aspx"):
    raise ValueError(
        "Doc.aspx URLs do not expose the file path. Use a copy link or a "
        "direct file URL instead.")

  for prefix in SERVER_RELATIVE_PATH_PREFIXES:
    if stripped_path.startswith(prefix):
      return stripped_path

  raise ValueError(f"Unsupported OneDrive URL path: {stripped_path}")
@

Shared links still reveal the target path through their [[id]] parameter,
while [[Doc2.aspx]] links only reveal the site path and the file id. This
helper separates those cases before the main parser builds the final
[[SharePointLocation]].
<<functions>>=
def _extract_file_reference(parsed) -> tuple:
  """Return ``(site_path, server_relative_path, file_id)`` from ``parsed``."""
  shared_path = _shared_link_relative_path(parsed)
  if shared_path is not None:
    return (_site_root_from_path(shared_path), shared_path, None)

  stripped_path = _strip_copy_link_prefix(urllib.parse.unquote(parsed.path))
  if "/_layouts/" in stripped_path:
    site_path = stripped_path.split("/_layouts/", 1)[0]
    query = urllib.parse.parse_qs(parsed.query)
    sourcedoc = query.get("sourcedoc")
    if sourcedoc:
      return (site_path, None, sourcedoc[-1].strip("{}"))
    raise ValueError(
        "Doc2.aspx URLs require a sourcedoc parameter. Use a copy link or a "
        "direct file URL instead.")

  server_relative_path = _extract_server_relative_path(parsed.path)
  return (_site_root_from_path(server_relative_path),
          server_relative_path,
          None)
@

The site URL is the stable prefix that owns the document library. Personal
OneDrive paths keep [[/personal/<user>]], while team sites keep
[[/sites/<name>]] or [[/teams/<name>]].
<<functions>>=
def _build_site_url(parsed, server_relative_path: str) -> str:
  """Return the SharePoint site URL for ``server_relative_path``."""
  parts = server_relative_path.lstrip("/").split("/")
  if len(parts) < 2 or parts[0] not in SHAREPOINT_SITE_ROOTS:
    raise ValueError(
        f"Unsupported SharePoint path: {server_relative_path}")

  site_path = f"/{parts[0]}/{parts[1]}"
  return urllib.parse.urlunsplit((parsed.scheme,
                                  parsed.netloc,
                                  site_path,
                                  "",
                                  ""))
@

<<constants>>=
ALL_ITEMS_PATH_SUFFIX = "/Forms/AllItems.aspx"
ALL_ITEMS_QUERY_KEYS = ("id", "RootFolder")
COPY_LINK_RE = re.compile(r"^/:[^:]+:/[a-z](/.*)$", re.IGNORECASE)
FOLDER_COPY_LINK_RE = re.compile(r"^/:f:/[a-z](/.*)$", re.IGNORECASE)
SERVER_RELATIVE_PATH_PREFIXES = (
    "/personal/",
    "/sites/",
    "/teams/",
)
SHAREPOINT_SITE_ROOTS = ("personal", "sites", "teams")
SHARED_LINK_PATH = "/shared"
@

