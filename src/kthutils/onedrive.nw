def get_download_name_by_url(self, url: str) -> str:
  """Return a suitable local file name for the file addressed by ``url``."""
  location = parse_sharepoint_url(url)
  if location.server_relative_path is not None:
    return location.name
  metadata_url = _file_metadata_url(location)
  self._ensure_login_handlers(location)
  response = self.__session.request(
      "GET",
      metadata_url,
      headers={"Accept": ODATA_VERBOSE_ACCEPT})
  logger.debug("SharePoint file metadata response status %s for %s",
               response.status_code,
               location.file_id)
  response.raise_for_status()
  name = _file_name_from_payload(response.json())
  if name:
    return name
  if location.file_id is not None:
    return location.file_id
  raise ValueError("SharePoint file metadata did not include a name")
