We also define fake HTTP responses and fake login handlers once since several
tests reuse them.
<<test helpers>>=
class FakeResponse:
  def __init__(self,
               *,
               json_data=None,
               content=b"",
               text="",
               status_code=200,
               headers=None):
    self._json_data = json_data
    self.content = content
    self.text = text
    self.status_code = status_code
    self.headers = dict(headers or {})

  def json(self):
    if self._json_data is None:
      raise ValueError()
    return self._json_data

  def raise_for_status(self):
    if self.status_code >= 400:
      raise RuntimeError(f"HTTP {self.status_code}")


class FakeHTTPSession:
  def __init__(self, responses=None):
    self.responses = list(responses or [FakeResponse()])
    self.requests = []
    self.handlers = []

  def add_handler(self, handler):
    if handler not in self.handlers:
      self.handlers.append(handler)

  def request(self,
              method,
              url,
              *,
              headers=None,
              params=None,
              json=None,
              data=None):
    self.requests.append({
      "method": method,
      "url": url,
      "headers": headers,
      "params": params,
      "json": json,
      "data": data,
    })
    return self.responses.pop(0)


class FakeSAMLlogin:
  def __init__(self, rerun_requests=False):
    self.rerun_requests = rerun_requests

  def __eq__(self, other):
    return (type(self) is type(other)
            and self.rerun_requests == other.rerun_requests)


class FakeUGlogin:
  def __init__(self,
               username,
               password,
               login_trigger_url=None,
               base_url=None,
               rerun_requests=False):
    self.username = username
    self.password = password
    self.login_trigger_url = login_trigger_url
    self.base_url = base_url
    self.rerun_requests = rerun_requests

  def __eq__(self, other):
    return (type(self) is type(other)
            and self.username == other.username
            and self.password == other.password
            and self.login_trigger_url == other.login_trigger_url
            and self.base_url == other.base_url
            and self.rerun_requests == other.rerun_requests)
