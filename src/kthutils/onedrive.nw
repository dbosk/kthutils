def _create_page(self,
                 location: SharePointLocation,
                 page_name: str,
                 title: str,
                 digest: str) -> int:
  """Create a blank SharePoint page and return its id."""
  response = self.__session.request(
      "POST",
      _sitepages_url(location, "pages"),
      headers={
          "Accept": ODATA_VERBOSE_ACCEPT,
          "Content-Type": ODATA_VERBOSE_ACCEPT,
          "X-RequestDigest": digest,
      },
      json={
          "__metadata": {"type": "SP.Publishing.SitePage"},
          "Title": title,
          "Name": page_name,
          "PageLayoutType": "Article",
      })
  logger.debug("SharePoint page creation response status %s for %s",
               response.status_code,
               page_name)
  response.raise_for_status()
  payload = response.json()
  try:
    return payload["d"]["Id"]
  except KeyError:
    try:
      return payload["Id"]
    except KeyError as exc:
      raise ValueError("SharePoint page creation did not return an id") from exc
