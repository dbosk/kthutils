LIST_DATA_OBJECT_TYPES = {
    "0": "file",
    "1": "dir",
}
LIST_DATA_RENDER_OPTIONS = 2
ODATA_NOMETADATA_ACCEPT = "application/json;odata=nometadata"
ODATA_VERBOSE_ACCEPT = "application/json;odata=verbose"
