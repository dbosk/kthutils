<<constants>>=
logger = logging.getLogger(__name__)
@

The shared session already knows how to handle KTH's Ladok SSO and Microsoft
Authenticator pages. SharePoint adds one missing hop: the generic KTH SAML relay
plus the [[UGlogin]] handler used by services behind [[login.ug.kth.se]].

We attach those handlers lazily per site. That keeps the constructor simple and
lets the same session talk to both personal OneDrive hosts and ordinary
SharePoint sites. The trigger URL comes from [[_login_trigger_url()]] so that
SharePoint's forms-auth header can steer [[UGlogin]] into a real login page.
<<[[OneDriveSession]] methods>>=
def _ensure_login_handlers(self, url: str, location: SharePointLocation):
  """Attach the KTH web-login handlers needed for ``location``."""
  if self.__username is None or self.__password is None:
    logger.debug("Skipping login handlers for %s because credentials are "
                 "unavailable",
                 location.site_url)
    return

  login_trigger_url = _login_trigger_url(url, location)
  logger.debug("Ensuring SharePoint login handlers for %s", location.site_url)
  logger.debug("UGlogin trigger URL is %s", login_trigger_url)
  self.__session.add_handler(weblogin.kth.SAMLlogin(rerun_requests=True))
  self.__session.add_handler(
      weblogin.kth.UGlogin(self.__username,
                           self.__password,
                           login_trigger_url=login_trigger_url,
                           base_url=location.site_url,
                           rerun_requests=True))
@

