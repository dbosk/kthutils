Site-root browsing hides system libraries and template libraries because they
are not useful in normal file workflows.
<<[[OneDriveSession]] methods>>=
def _get_document_libraries(self, location: SharePointLocation) -> list:
  """Return visible document libraries for the SharePoint site."""
  logger.debug("Discovering document libraries for %s", location.site_url)
  self._ensure_login_handlers(location)
  response = self.__session.request(
      "GET",
      _document_libraries_url(location),
      headers={"Accept": ODATA_VERBOSE_ACCEPT})
  logger.debug("SharePoint library discovery response status %s for %s",
               response.status_code,
               location.site_url)
  response.raise_for_status()
  libraries = []
  for library in _odata_results(response.json()):
    title = library.get("Title", "")
    if library.get("Hidden") or title in DOCUMENT_LIBRARY_TITLES_TO_SKIP:
      continue
    root_folder = library.get("RootFolder") or {}
    path = root_folder.get("ServerRelativeUrl")
    if not path:
      continue
    libraries.append({"title": title, "path": path})
  libraries.sort(key=lambda library: library["title"].casefold())
  return libraries
