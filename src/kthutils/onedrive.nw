<<[[OneDriveSession]] methods>>=
def _find_page_id(self,
                  location: SharePointLocation,
                  page_name: str,
                  digest: str) -> Optional[int]:
  """Return the existing SharePoint page id for ``page_name``."""
  response = self.__session.request(
      "GET",
      _page_lookup_url(location, page_name),
      headers={
          "Accept": ODATA_VERBOSE_ACCEPT,
          "X-RequestDigest": digest,
      })
  logger.debug("SharePoint page lookup response status %s for %s",
               response.status_code,
               page_name)
  response.raise_for_status()
  results = _odata_results(response.json())
  if not results:
    return None
  try:
    return results[0]["Id"]
  except KeyError as exc:
    raise ValueError("SharePoint page lookup did not return an id") from exc
