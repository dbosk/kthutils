def test_login_trigger_uses_sharepoint_forms_header(monkeypatch):
  calls = []

  def fake_get(url, allow_redirects=False, timeout=None):
    calls.append({
      "url": url,
      "allow_redirects": allow_redirects,
      "timeout": timeout,
    })
    return FakeResponse(headers={
        "X-Forms_Based_Auth_Required":
            "https://kth-my.sharepoint.com/_forms/default.aspx?Source=%2f"
            "personal%2fuser"
    })

  monkeypatch.setattr(kthutils.onedrive.requests, "get", fake_get)

  location = kthutils.onedrive.parse_sharepoint_url(copy_link_url)

  assert kthutils.onedrive._login_trigger_url(copy_link_url, location) == (
      "https://kth-my.sharepoint.com/_forms/default.aspx?Source=%2fpersonal"
      "%2fuser")
  assert calls == [{
      "url": copy_link_url,
      "allow_redirects": False,
      "timeout": 15,
  }]


def test_login_trigger_falls_back_to_site_url(monkeypatch):
  responses = [
      FakeResponse(),
      FakeResponse(headers={
          "X-Forms_Based_Auth_Required":
              "https://kth.sharepoint.com/_forms/default.aspx?Source=%2f"
              "sites%2fexample"
      }),
  ]
  calls = []

  def fake_get(url, allow_redirects=False, timeout=None):
    calls.append(url)
    return responses.pop(0)

  monkeypatch.setattr(kthutils.onedrive.requests, "get", fake_get)

  location = kthutils.onedrive.parse_sharepoint_url(site_file_url)

  assert kthutils.onedrive._login_trigger_url(site_file_url, location) == (
      "https://kth.sharepoint.com/_forms/default.aspx?Source=%2fsites"
      "%2fexample")
  assert calls == [site_file_url, "https://kth.sharepoint.com/sites/example"]
