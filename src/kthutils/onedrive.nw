The default [[get]] behaviour uses the remote file name when the URL exposes
one directly, and falls back to metadata lookup only for file-id links.
<<command definitions>>=
@cli.command(name="get")
def cli_get(url: Annotated[str, url_arg],
            output: Annotated[Optional[pathlib.Path], output_arg] = None):
  """Download a file from OneDrive or SharePoint."""
  session = OneDriveSession()
  if output is None:
    location = parse_sharepoint_url(url)
    if location.server_relative_path is not None:
      output = pathlib.Path(location.name)
    else:
      output = pathlib.Path(session.get_download_name_by_url(url))
  logger.debug("Writing downloaded file to %s", output)
  output.write_bytes(session.get_by_url(url))
@

Short [[ls]] output stays tab-separated and shell-friendly, while the long
form reuses the richer folder metadata and prints library headers when the
user points at a site root.
<<command definitions>>=
@cli.command(name="ls")
def cli_ls(url: Annotated[str, folder_url_arg],
           long: Annotated[bool, long_opt] = False):
  """List the direct contents of a OneDrive or SharePoint folder."""
  session = OneDriveSession()
  if not long:
    for kind, name in session.list_by_url(url):
      print(f"{kind}\t{name}")
    return

  listings = session.list_detailed_by_url(url)
  for index, listing in enumerate(listings):
    if index:
      print()
    if len(listings) > 1:
      print(f"{listing['label']}/")
    _print_long_listing(listing["entries"])
@

The recursive commands both use the same tree printer. The difference is only
whether files are included or filtered away.
<<command definitions>>=
@cli.command(name="tree")
def cli_tree(url: Annotated[str, folder_url_arg],
             max_depth: Annotated[Optional[int],
                                  typer.Argument(help="Maximum recursion "
                                                      "depth.")] = None):
  """Print a recursive tree of files and folders."""
  session = OneDriveSession()
  listings = session.iter_folder_locations(url)
  total_dirs = 0
  total_files = 0
  for index, (label, location) in enumerate(listings):
    if index:
      print()
    print(f"{label}/")
    stats = _print_tree(session, location, max_depth=max_depth)
    total_dirs += stats["dirs"]
    total_files += stats["files"]
  print()
  print(f"{total_dirs} directories, {total_files} files")
@

<<command definitions>>=
@cli.command(name="folders")
def cli_folders(url: Annotated[str, folder_url_arg],
                max_depth: Annotated[Optional[int],
                                     typer.Argument(help="Maximum recursion "
                                                         "depth.")] = None):
  """Print a recursive tree of folders only."""
  session = OneDriveSession()
  listings = session.iter_folder_locations(url)
  total_dirs = 0
  for index, (label, location) in enumerate(listings):
    if index:
      print()
    print(f"{label}/")
    stats = _print_tree(session,
                        location,
                        max_depth=max_depth,
                        folders_only=True)
    total_dirs += stats["dirs"]
  print()
  print(f"{total_dirs} directories")
