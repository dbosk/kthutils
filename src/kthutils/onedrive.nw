Uploads still only need the local bytes plus the remote URL.
<<command definitions>>=
@cli.command(name="put")
def cli_put(local_path: Annotated[pathlib.Path, local_path_arg],
            url: Annotated[str, url_arg],
            overwrite: Annotated[bool, overwrite_opt] = True):
  """Upload a local file to OneDrive or SharePoint."""
  logger.debug("Reading local upload payload from %s", local_path)
  OneDriveSession().put_by_url(url,
                               local_path.read_bytes(),
                               overwrite=overwrite)
@

Page publishing derives reasonable defaults from the HTML file name, but it
still lets the caller override both the page file name and the page title.
<<command definitions>>=
@page_cli.command(name="publish")
def cli_page_publish(site_url: Annotated[str, site_url_arg],
                     html_file: Annotated[pathlib.Path, html_path_arg],
                     page_name: Annotated[Optional[str], page_name_opt] = None,
                     title: Annotated[Optional[str], page_title_opt] = None):
  """Create or update and publish a modern SharePoint page."""
  if page_name is None:
    page_name = _normalise_page_name(html_file.stem)
  else:
    page_name = _normalise_page_name(page_name)
  if title is None:
    title = pathlib.Path(page_name).stem.replace("-", " ")

  page_url, status = OneDriveSession().publish_page_by_url(
      site_url,
      html_file.read_text(encoding="utf-8"),
      page_name,
      title)
  print(f"{status}\t{page_url}")
