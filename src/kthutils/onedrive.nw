@

When the user points [[ls]], [[tree]], or [[folders]] at a site root, we have
to discover the document libraries first. We keep the OData query explicit so
the generated URLs stay stable and testable.
<<functions>>=
def _document_libraries_url(location: SharePointLocation) -> str:
  """Return the REST endpoint for listing document libraries."""
  query = "&".join((
      "$filter=" + urllib.parse.quote_plus(
          "BaseTemplate eq 101 or BaseTemplate eq 700",
          safe="$'()"),
      "$select=" + urllib.parse.quote_plus(
          "Title,BaseTemplate,Hidden,RootFolder/ServerRelativeUrl",
          safe="$'()"),
      "$expand=" + urllib.parse.quote_plus("RootFolder", safe="$'()"),
  ))
  return f"{location.site_url}/_api/web/lists?{query}"
@

The list-view endpoint still needs a small JSON payload telling SharePoint
which folder to render.
<<functions>>=
def _render_list_data_body(location: SharePointLocation) -> dict:
  """Return the list-view request payload for listing ``location``."""
  return {
      "parameters": {
          "RenderOptions": LIST_DATA_RENDER_OPTIONS,
          "AddRequiredFields": True,
          "FolderServerRelativeUrl": location.server_relative_path,
      }
  }
@

Page publishing uses the classic [[sitepages]] REST surface. The helper URLs
are small enough that testing them directly is cheaper than discovering a bug
through a live site update.
<<functions>>=
def _sitepages_url(location: SharePointLocation, endpoint: str) -> str:
  """Return the site-pages API endpoint for ``location``."""
  return f"{location.site_url}/_api/sitepages/{endpoint}"
@

<<functions>>=
def _page_lookup_url(location: SharePointLocation, page_name: str) -> str:
  """Return the page-lookup endpoint for ``page_name``."""
  query = "&".join((
      "$filter=" + urllib.parse.quote_plus(
          f"Name eq '{_escape_odata_string(page_name)}'",
          safe="$'()"),
      "$select=" + urllib.parse.quote_plus("Id,Name", safe="$'()"),
  ))
  return f"{_sitepages_url(location, 'pages')}?{query}"
@

<<functions>>=
def _normalise_page_name(page_name: str) -> str:
  """Return ``page_name`` with a SharePoint page suffix."""
  if page_name.lower().endswith(".aspx"):
    return page_name
  return f"{page_name}.aspx"
@

<<functions>>=
def _site_page_url(location: SharePointLocation, page_name: str) -> str:
  """Return the browser URL for a SharePoint page."""
  page_name = _normalise_page_name(page_name)
  quoted_name = urllib.parse.quote(page_name)
  return f"{location.site_url}/SitePages/{quoted_name}"
