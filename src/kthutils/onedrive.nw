SharePoint returns a mix of list-view rows, verbose OData payloads, and a few
odd timestamp formats. We keep the extraction and formatting logic in small
helpers so the session methods stay focused on request flow.
<<functions>>=
def _list_data_rows(payload) -> list:
  """Return the rows from a SharePoint list-view payload."""
  try:
    return payload["Row"]
  except KeyError as exc:
    raise ValueError("SharePoint did not return list rows") from exc
@

<<functions>>=
def _list_data_entry(row) -> tuple:
  """Return one ``(kind, name)`` pair from a SharePoint list row."""
  try:
    return (LIST_DATA_OBJECT_TYPES[str(row["FSObjType"])],
            row["FileLeafRef"])
  except KeyError as exc:
    raise ValueError(
        "SharePoint list row did not contain the expected fields") from exc
@

<<functions>>=
def _odata_results(payload) -> list:
  """Return list results from an OData response payload."""
  if "value" in payload:
    return payload["value"]
  try:
    return payload["d"]["results"]
  except KeyError as exc:
    raise ValueError("SharePoint did not return list results") from exc
@

<<functions>>=
def _folder_items_from_payloads(files_payload, folders_payload) -> list:
  """Return combined file and folder entries from SharePoint payloads."""
  entries = []
  for folder in _odata_results(folders_payload):
    name = folder.get("Name")
    if not name:
      continue
    entries.append({
        "kind": "dir",
        "name": name,
        "server_relative_path": folder.get("ServerRelativeUrl"),
        "size": None,
        "modified": folder.get("TimeLastModified"),
    })
  for file_entry in _odata_results(files_payload):
    name = file_entry.get("Name")
    if not name:
      continue
    entries.append({
        "kind": "file",
        "name": name,
        "server_relative_path": file_entry.get("ServerRelativeUrl"),
        "size": _coerce_sharepoint_int(file_entry.get("Length")),
        "modified": file_entry.get("TimeLastModified"),
    })
  entries.sort(key=lambda entry: (entry["kind"],
                                  entry["name"].casefold(),
                                  entry["name"]))
  return entries
@

<<functions>>=
def _file_name_from_payload(payload) -> Optional[str]:
  """Return a file name from a SharePoint metadata payload when present."""
  if "Name" in payload:
    return payload["Name"]
  try:
    return payload["d"]["Name"]
  except KeyError:
    return None
@

<<functions>>=
def _coerce_sharepoint_int(value) -> Optional[int]:
  """Return ``value`` as an integer when possible."""
  if value in (None, ""):
    return None
  try:
    return int(value)
  except (TypeError, ValueError):
    return None
@

<<functions>>=
def _format_size(size_bytes: Optional[int]) -> str:
  """Return ``size_bytes`` formatted for display."""
  if size_bytes is None:
    return ""
  if size_bytes < 1024:
    return f"{size_bytes} B"
  if size_bytes < 1024 * 1024:
    return f"{size_bytes / 1024:.1f} KB"
  if size_bytes < 1024 * 1024 * 1024:
    return f"{size_bytes / (1024 * 1024):.1f} MB"
  return f"{size_bytes / (1024 * 1024 * 1024):.1f} GB"
@

<<functions>>=
def _format_date(date_str: Optional[str]) -> str:
  """Return ``date_str`` formatted for display."""
  if not date_str:
    return ""
  if date_str.startswith("/Date("):
    try:
      millis = int(date_str.split("(", 1)[1].split(")", 1)[0])
    except ValueError:
      return date_str
    return datetime.datetime.fromtimestamp(millis / 1000,
                                           datetime.timezone.utc).strftime(
        "%Y-%m-%d %H:%M")
  try:
    return datetime.datetime.strptime(
        date_str.replace("Z", ""),
        "%Y-%m-%dT%H:%M:%S").strftime("%Y-%m-%d %H:%M")
  except ValueError:
    return date_str
@

<<functions>>=
def _print_long_listing(entries: list) -> None:
  """Print ``entries`` with size and modification time."""
  if not entries:
    print("(empty folder)")
    return
  for entry in entries:
    print("{}\t{}\t{}\t{}".format(entry["kind"],
                                     _format_size(entry["size"]),
                                     _format_date(entry["modified"]),
                                     entry["name"]))
@

<<functions>>=
def _visible_tree_entries(entries: list, folders_only: bool) -> list:
  """Return the entries that should be shown in tree views."""
  visible = []
  for entry in entries:
    if entry["kind"] == "dir":
      if entry["name"].startswith("_") or entry["name"] in SYSTEM_FOLDER_NAMES:
        continue
      visible.append(entry)
      continue
    if not folders_only:
      visible.append(entry)
  return visible
@

<<functions>>=
def _print_tree(session: OneDriveSession,
                location: SharePointLocation,
                prefix: str = "",
                max_depth: Optional[int] = None,
                depth: int = 0,
                folders_only: bool = False,
                stats: Optional[dict] = None) -> dict:
  """Recursively print a SharePoint folder tree."""
  if stats is None:
    stats = {"dirs": 0, "files": 0}
  if max_depth is not None and depth > max_depth:
    return stats

  entries = _visible_tree_entries(session._list_folder_items(location),
                                  folders_only)
  for index, entry in enumerate(entries):
    is_last = index == len(entries) - 1
    connector = TREE_BRANCH_LAST if is_last else TREE_BRANCH_MID
    if entry["kind"] == "dir":
      stats["dirs"] += 1
      print(f"{prefix}{connector}{entry['name']}/")
      if max_depth is not None and depth >= max_depth:
        continue
      child_path = entry.get("server_relative_path")
      if child_path is None:
        continue
      child_location = SharePointLocation(site_url=location.site_url,
                                          server_relative_path=child_path)
      _print_tree(session,
                  child_location,
                  prefix + (TREE_PREFIX_LAST if is_last else TREE_PREFIX_MID),
                  max_depth=max_depth,
                  depth=depth + 1,
                  folders_only=folders_only,
                  stats=stats)
      continue

    stats["files"] += 1
    size = _format_size(entry["size"])
    if size:
      print(f"{prefix}{connector}{entry['name']}  [{size}]")
    else:
      print(f"{prefix}{connector}{entry['name']}")
  return stats
@

