Folder-oriented operations accept more browser URL shapes, including site
roots and [[AllItems.aspx]] views. We keep that logic separate so the file
parser can remain strict.
<<functions>>=
def parse_sharepoint_folder_url(url: str) -> SharePointLocation:
  """Resolve a SharePoint URL or server-relative folder path."""
  url = _resolve_sharepoint_url(url)
  parsed = urllib.parse.urlsplit(url)
  if not parsed.scheme or not parsed.netloc:
    raise ValueError(f"Unsupported OneDrive URL: {url}")

  server_relative_path = _extract_folder_relative_path(parsed)
  return SharePointLocation(
      site_url=_build_site_url(parsed, server_relative_path),
      server_relative_path=server_relative_path)
@

Shared links, folder copy links, and [[AllItems.aspx]] pages all carry the
same logical information in different places. We normalise them into one
server-relative path before the session code sees them.
<<functions>>=
def _extract_folder_relative_path(parsed) -> str:
  """Return the server-relative folder path embedded in ``parsed``."""
  shared_path = _shared_link_relative_path(parsed)
  if shared_path is not None:
    return _normalise_folder_relative_path(shared_path)

  decoded_path = urllib.parse.unquote(parsed.path)
  stripped_path = _strip_copy_link_prefix(decoded_path)
  if "/_layouts/" in stripped_path:
    raise ValueError(
        "Document URLs do not expose a folder path. Use a folder copy link, "
        "site root, or direct folder URL instead.")
  if stripped_path.lower().endswith("/doc.aspx"):
    raise ValueError(
        "Doc.aspx URLs do not expose the folder path. Use a copy link or a "
        "direct folder URL instead.")

  if stripped_path.lower().endswith(ALL_ITEMS_PATH_SUFFIX.lower()):
    query = urllib.parse.parse_qs(parsed.query)
    for key in ALL_ITEMS_QUERY_KEYS:
      values = query.get(key)
      if values:
        return _normalise_folder_relative_path(values[-1])
    return _normalise_folder_relative_path(
        stripped_path[:-len(ALL_ITEMS_PATH_SUFFIX)])

  return _normalise_folder_relative_path(stripped_path)
@

Query parameters sometimes contain a full URL and sometimes only a path. We
drop a trailing slash, but keep the root slash itself.
<<functions>>=
def _normalise_folder_relative_path(path: str) -> str:
  """Return ``path`` as a normalised server-relative folder path."""
  decoded_path = urllib.parse.unquote(path)
  parsed = urllib.parse.urlsplit(decoded_path)
  if parsed.scheme or parsed.netloc:
    decoded_path = parsed.path
  if decoded_path.lower().endswith(ALL_ITEMS_PATH_SUFFIX.lower()):
    decoded_path = decoded_path[:-len(ALL_ITEMS_PATH_SUFFIX)]
  if decoded_path.endswith("/") and decoded_path != "/":
    decoded_path = decoded_path.rstrip("/")

  for prefix in SERVER_RELATIVE_PATH_PREFIXES:
    if decoded_path.startswith(prefix):
      return decoded_path

  raise ValueError(f"Unsupported OneDrive folder path: {decoded_path}")
@

The remaining helpers are small but central. Shared links reveal their target
in the [[id]] parameter, copy links add a leading marker segment, and site-
root browsing needs to distinguish [[/sites/<name>]] from deeper paths.
<<functions>>=
def _shared_link_relative_path(parsed) -> Optional[str]:
  """Return the server-relative path encoded in a SharePoint shared link."""
  if parsed.path.rstrip("/").lower() != SHARED_LINK_PATH:
    return None
  query = urllib.parse.parse_qs(parsed.query)
  values = query.get("id")
  if not values:
    raise ValueError("Shared SharePoint links must include an id parameter")
  return _normalise_folder_relative_path(values[-1])
@

<<functions>>=
def _strip_copy_link_prefix(path: str) -> str:
  """Return ``path`` without SharePoint copy-link prefixes."""
  match = COPY_LINK_RE.match(path)
  if match:
    return match.group(1)
  return path
@

<<functions>>=
def _site_root_from_path(server_relative_path: str) -> str:
  """Return the SharePoint site root for ``server_relative_path``."""
  parts = server_relative_path.lstrip("/").split("/")
  if len(parts) < 2 or parts[0] not in SHAREPOINT_SITE_ROOTS:
    raise ValueError(f"Unsupported SharePoint path: {server_relative_path}")
  return "/" + "/".join(parts[:2])
@

<<functions>>=
def _is_site_root_path(server_relative_path: Optional[str]) -> bool:
  """Return whether ``server_relative_path`` identifies a site root."""
  if server_relative_path is None:
    return False
  return server_relative_path == _site_root_from_path(server_relative_path)
@

<<functions>>=
def _location_label(location: SharePointLocation) -> str:
  """Return a readable label for ``location``."""
  if location.server_relative_path is None:
    site_path = urllib.parse.urlsplit(location.site_url).path
    return site_path.rstrip("/").split("/")[-1]
  return pathlib.PurePosixPath(location.server_relative_path).name
@

<<functions>>=
def _expand_sharepoint_shorthand(url: str) -> str:
  """Return ``url`` expanded from supported SharePoint shorthands."""
  if not url.startswith("http") and ":" not in url and "/" not in url:
    if "ug_kth_se" in url:
      return f"{ONEDRIVE_HOST_ROOT}/personal/{url}"
    return f"{SHAREPOINT_HOST_ROOT}/sites/{url}"

  match = re.match(r"^(kth(?:-my)?):(.*)$", url)
  if not match:
    return url

  prefix, path = match.groups()
  if not path.startswith("/"):
    if path.startswith(("sites/", "teams/", "personal/")):
      path = "/" + path
    elif prefix == "kth-my":
      path = f"/personal/{path}"
    else:
      path = f"/sites/{path}"
  return SHORTHAND_HOST_ROOTS[prefix] + path
@

