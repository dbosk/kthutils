Page publishing follows the same authenticated-session pattern as uploads,
but the flow is slightly richer: discover or create the page, save its rich-
text canvas as a draft, and then publish it.
<<[[OneDriveSession]] methods>>=
def publish_page_by_url(self,
                        url: str,
                        html_content: str,
                        page_name: str,
                        title: str) -> tuple:
  """Create or update and publish a modern SharePoint page."""
  location = parse_sharepoint_folder_url(url)
  page_name = _normalise_page_name(page_name)
  self._ensure_login_handlers(location)
  digest = self._get_form_digest(location)
  page_id = self._find_page_id(location, page_name, digest)
  status = "updated" if page_id is not None else "created"
  if page_id is None:
    page_id = self._create_page(location, page_name, title, digest)
  self._save_page_draft(location, page_id, title, html_content, digest)
  self._publish_page(location, page_id, digest)
  return _site_page_url(location, page_name), status
