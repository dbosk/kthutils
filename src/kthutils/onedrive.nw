SharePoint requires a form digest for write requests. The digest comes from the
site's [[contextinfo]] endpoint and is short-lived, so we fetch it on demand for
each upload.
<<constants>>=
FORM_DIGEST_ACCEPT = "application/json;odata=verbose"
@

<<[[OneDriveSession]] methods>>=
def _get_form_digest(self, location: SharePointLocation) -> str:
  """Fetch the SharePoint form digest for ``location.site_url``."""
  logger.debug("Requesting SharePoint form digest from %s", location.site_url)
  response = self.__session.request(
      "POST",
      f"{location.site_url}/_api/contextinfo",
      headers={"Accept": FORM_DIGEST_ACCEPT})
  logger.debug("SharePoint form digest response status %s",
               response.status_code)
  response.raise_for_status()
  payload = response.json()
  try:
    return payload["d"]["GetContextWebInformation"]["FormDigestValue"]
  except KeyError as exc:
    raise ValueError("SharePoint did not return a form digest") from exc
@

The read path is deliberately small: resolve the browser URL, ensure login
handlers are present, request the file bytes, and raise an error on HTTP
failure.
<<[[OneDriveSession]] methods>>=
def get_by_url(self, url: str) -> bytes:
  """Download the file addressed by ``url``."""
  location = parse_sharepoint_url(url)
  logger.debug("Downloading %s from %s",
               location.server_relative_path,
               location.site_url)
  self._ensure_login_handlers(url, location)
  response = self.__session.request("GET", _download_url(location))
  logger.debug("SharePoint download response status %s for %s",
               response.status_code,
               location.server_relative_path)
  response.raise_for_status()
  return response.content
@

For writes we follow the same outline, but insert the form-digest step and send
the raw bytes as the POST body.
<<[[OneDriveSession]] methods>>=
def put_by_url(self,
               url: str,
               data: bytes,
               overwrite: bool = True) -> None:
  """Upload ``data`` to the file addressed by ``url``."""
  location = parse_sharepoint_url(url)
  logger.debug("Uploading %s to %s (overwrite=%s, bytes=%s)",
               location.server_relative_path,
               location.site_url,
               overwrite,
               len(data))
  self._ensure_login_handlers(url, location)
  digest = self._get_form_digest(location)
  response = self.__session.request(
      "POST",
      _upload_url(location, overwrite),
      headers={"X-RequestDigest": digest},
      data=data)
  logger.debug("SharePoint upload response status %s for %s",
               response.status_code,
               location.server_relative_path)
  response.raise_for_status()
@

