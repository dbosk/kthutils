  monkeypatch.setattr(kthutils.onedrive.requests, "get", fake_get)

  location = kthutils.onedrive.parse_sharepoint_url(site_file_url)

  assert kthutils.onedrive._login_trigger_url(site_file_url, location) == (
      "https://kth.sharepoint.com/_forms/default.aspx?Source=%2fsites"
      "%2fexample")
  assert calls == [site_file_url, "https://kth.sharepoint.com/sites/example"]
