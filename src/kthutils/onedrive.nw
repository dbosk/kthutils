Uploads still require a path-based target, because SharePoint's upload
endpoint addresses the destination folder rather than an existing file id.
<<[[OneDriveSession]] methods>>=
def put_by_url(self,
               url: str,
               data: bytes,
               overwrite: bool = True) -> None:
  """Upload ``data`` to the file addressed by ``url``."""
  location = parse_sharepoint_url(url)
  if location.server_relative_path is None:
    raise ValueError(
        "Cannot upload using a SharePoint file-ID URL; use a direct "
        "file path or copy link instead.")
  logger.debug("Uploading %s to %s (overwrite=%s, bytes=%s)",
               location.server_relative_path,
               location.site_url,
               overwrite,
               len(data))
  self._ensure_login_handlers(location)
  digest = self._get_form_digest(location)
  response = self.__session.request(
      "POST",
      _upload_url(location, overwrite),
      headers={"X-RequestDigest": digest},
      data=data)
  logger.debug("SharePoint upload response status %s for %s",
               response.status_code,
               location.server_relative_path)
  response.raise_for_status()
