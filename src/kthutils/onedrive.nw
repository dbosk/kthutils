<<[[OneDriveSession]] methods>>=
def _get_form_digest(self, location: SharePointLocation) -> str:
  """Fetch the SharePoint form digest for ``location.site_url``."""
  logger.debug("Requesting SharePoint form digest from %s", location.site_url)
  response = self.__session.request(
      "POST",
      f"{location.site_url}/_api/contextinfo",
      headers={"Accept": ODATA_VERBOSE_ACCEPT})
  logger.debug("SharePoint form digest response status %s",
               response.status_code)
  response.raise_for_status()
  payload = response.json()
  try:
    return payload["d"]["GetContextWebInformation"]["FormDigestValue"]
  except KeyError as exc:
   raise ValueError("SharePoint did not return a form digest") from exc
@

SharePoint's list-view endpoint returns rows directly at the top level. We keep
the payload extraction and row classification in helpers so [[list_by_url()]]
stays focused on the request and the final output order.
<<functions>>=
def _list_data_rows(payload) -> list:
  """Return the rows from a SharePoint list-view payload."""
  try:
    return payload["Row"]
  except KeyError as exc:
    raise ValueError("SharePoint did not return list rows") from exc
@

<<functions>>=
def _list_data_entry(row) -> tuple:
  """Return one ``(kind, name)`` pair from a SharePoint list row."""
  try:
    return (LIST_DATA_OBJECT_TYPES[str(row["FSObjType"])],
            row["FileLeafRef"])
  except KeyError as exc:
    raise ValueError(
        "SharePoint list row did not contain the expected fields") from exc
@

Listing still begins by resolving the browser URL and ensuring the login
handlers are available, but the actual data comes from SharePoint's list-view
pipeline rather than the denied [[/Folders]] and [[/Files]] collections. The
same [[RenderListDataAsStream]] endpoint also gives us the right forms-auth
trigger, so [[UGlogin]] still bootstraps from the exact endpoint we will call
next.
<<[[OneDriveSession]] methods>>=
def list_by_url(self, url: str) -> list:
  """List the direct children of the folder addressed by ``url``."""
  location = parse_sharepoint_folder_url(url)
  list_data_url = _render_list_data_url(location)
  logger.debug("Listing %s from %s",
               location.server_relative_path,
               location.site_url)
  self._ensure_login_handlers(list_data_url, location)

  response = self.__session.request(
      "POST",
      list_data_url,
      headers={
          "Accept": ODATA_NOMETADATA_ACCEPT,
          "Content-Type": ODATA_NOMETADATA_ACCEPT,
      },
      json=_render_list_data_body(location))
  logger.debug("SharePoint list-data response status %s for %s",
               response.status_code,
               location.server_relative_path)
  response.raise_for_status()

  entries = [_list_data_entry(row) for row in _list_data_rows(response.json())]
  entries.sort(key=lambda entry: (entry[0], entry[1].casefold(), entry[1]))
  return entries
@

The read path is deliberately small: resolve the browser URL, ensure login
handlers are present, request the file bytes, and raise an error on HTTP
failure.
<<[[OneDriveSession]] methods>>=
def get_by_url(self, url: str) -> bytes:
  """Download the file addressed by ``url``."""
  location = parse_sharepoint_url(url)
  logger.debug("Downloading %s from %s",
               location.server_relative_path,
               location.site_url)
  self._ensure_login_handlers(url, location)
  response = self.__session.request("GET", _download_url(location))
  logger.debug("SharePoint download response status %s for %s",
               response.status_code,
               location.server_relative_path)
  response.raise_for_status()
  return response.content
@

For writes we follow the same outline, but insert the form-digest step and send
the raw bytes as the POST body.
<<[[OneDriveSession]] methods>>=
def put_by_url(self,
               url: str,
               data: bytes,
               overwrite: bool = True) -> None:
  """Upload ``data`` to the file addressed by ``url``."""
  location = parse_sharepoint_url(url)
  logger.debug("Uploading %s to %s (overwrite=%s, bytes=%s)",
               location.server_relative_path,
               location.site_url,
               overwrite,
               len(data))
  self._ensure_login_handlers(url, location)
  digest = self._get_form_digest(location)
  response = self.__session.request(
      "POST",
      _upload_url(location, overwrite),
      headers={"X-RequestDigest": digest},
      data=data)
  logger.debug("SharePoint upload response status %s for %s",
               response.status_code,
               location.server_relative_path)
  response.raise_for_status()
@

