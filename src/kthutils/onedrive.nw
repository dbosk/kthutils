  class FakeOneDriveSession:
    def put_by_url(self, url, data, overwrite=True):
      uploaded["url"] = url
      uploaded["data"] = data
      uploaded["overwrite"] = overwrite

  monkeypatch.setattr(kthutils.onedrive,
                      "OneDriveSession",
                      lambda: FakeOneDriveSession())

  result = runner.invoke(onedrive_cli,
                         ["put", str(local_path), site_file_url,
                          "--no-overwrite"])

  assert result.exit_code == 0
  assert uploaded == {
      "url": site_file_url,
      "data": b"hello",
      "overwrite": False,
  }


def test_cli_ls_prints_type_and_name(monkeypatch):
  class FakeOneDriveSession:
    def list_by_url(self, url):
      assert url == allitems_root_url
      return [("dir", "Plans"), ("file", "Exam memo.pdf")]

  monkeypatch.setattr(kthutils.onedrive,
                      "OneDriveSession",
                      lambda: FakeOneDriveSession())

  result = runner.invoke(onedrive_cli, ["ls", allitems_root_url])

  assert result.exit_code == 0
  assert result.stdout == "dir\tPlans\nfile\tExam memo.pdf\n"
