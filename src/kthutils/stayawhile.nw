def test_cli_views_current_queue(monkeypatch):
  fake = FakeStayawhileSession()
  monkeypatch.setattr(kthutils.stayawhile, "get_session", lambda: fake)

  with runner.isolated_filesystem():
    result = runner.invoke(kthutils.stayawhile.cli,
                           ["view", "Queue", "--from", "2026-03-01"])

  assert result.exit_code == 0
  assert fake.calls == [("get_queue_log", "Queue", "2026-03-01", None)]
  assert parse_csv_output(result.stdout) == [
    ["position", "realname", "username", "ugkthid", "type", "joined_at"],
    ["1", "Grace Hopper", "student1", "u1student", "help",
     "2026-03-01T10:00:00Z"],
    ["2", "Ada Lovelace", "present1", "u1present", "present",
     "2026-03-01T10:05:00Z"],
  ]
  warnings = kthutils.stayawhile.queue_view_warnings(
      fake.get_queue_log("Queue", "2026-03-01", None),
      kthutils.stayawhile.reconstruct_current_queue(
          fake.get_queue_log("Queue", "2026-03-01", None)))
  assert warnings == [
    "reconstructed queue has 2 active entries, but latest queue_length is 3",
    "reconstructed queue has 1 present entries, but latest present_amount is 2",
  ]
