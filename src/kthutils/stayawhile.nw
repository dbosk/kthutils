The commands that read tabular data should adapt to their output target.
When we print to a terminal, a clean table is easier to scan.
When we print to a pipe or file, tab-separated CSV is easier to post-process
with standard POSIX tools such as [[cut]].
<<helper functions>>=
def is_tty():
  """Return whether standard output is a terminal."""
  return sys.stdout.isatty()


def value_to_text(value):
  """Return a stable textual representation of [[value]]."""
  if value is None:
    return ""
  if isinstance(value, bool):
    return str(value).lower()
  if isinstance(value, (dict, list)):
    return json.dumps(value)
  return str(value)


def print_csv_rows(rows, fields, headers=None):
  """Print [[rows]] as CSV with the given [[fields]]."""
  writer = csv.writer(sys.stdout, delimiter="\t")
  writer.writerow(headers or fields)
  for row in rows:
    writer.writerow([value_to_text(row.get(field)) for field in fields])


def print_rich_table(rows, fields, headers=None):
  """Print [[rows]] as a clean Rich table."""
  table = Table(box=None, show_edge=False, pad_edge=False)
  for header in headers or fields:
    table.add_column(header)
  for row in rows:
    table.add_row(*[value_to_text(row.get(field)) for field in fields])

  Console(file=sys.stdout).print(table)


def print_records(rows, fields, headers=None, tty=None):
  """Print tabular [[rows]] either as Rich output or as CSV."""
  rows = list(rows)
  if tty is None:
    tty = is_tty()

  if tty:
    print_rich_table(rows, fields, headers=headers)
  else:
    print_csv_rows(rows, fields, headers=headers)
