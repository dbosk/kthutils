def test_stayawhile_login_refreshes_expired_session_token():
  fake_http = FakeHTTPSession([
    FakeResponse(json_data={}),
    FakeResponse(json_data={}),
    FakeResponse(json_data=[{"id": 2}]),
  ])
  fake_http.cookies.set("userdata",
      '{"token":"fresh-jwt"}',
      domain="queue.eecs.kth.se")
  handler = kthutils.stayawhile.StayawhileLogin(
      "https://queue.eecs.kth.se")
  response = FakeResponse(
      status_code=403,
      url="https://queue.eecs.kth.se/api/api_keys")

  rerun = handler.login(
      fake_http,
      response,
      args=("GET", "https://queue.eecs.kth.se/api/api_keys"),
      kwargs={"headers": {"Authorization": "Token stale-jwt"}})

  assert rerun.json() == [{"id": 2}]
  assert fake_http.requests[0]["url"] == "https://queue.eecs.kth.se/login"
  assert fake_http.requests[1]["url"] == "https://queue.eecs.kth.se/login"
  assert fake_http.requests[2]["headers"] == {
    "Authorization": "Token fresh-jwt"
  }


def test_stayawhile_login_only_claims_session_token_endpoints():
  handler = kthutils.stayawhile.StayawhileLogin(
      "https://queue.eecs.kth.se")

