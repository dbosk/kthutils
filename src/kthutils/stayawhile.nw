\section{API keys}

The API lets users manage their own API keys.
We expose the same operations directly on the session object.
<<[[StayawhileSession]] methods>>=
def list_api_keys(self):
  """Return the caller's API keys."""
  return self._request("GET", "/api/api_keys")


def create_api_key(self, label=None):
  """Create a new API key."""
  if label is None:
    return self._request("POST", "/api/api_keys")
  return self._request("POST", "/api/api_keys",
                       payload={"label": label})


def revoke_api_key(self, api_key_id):
  """Revoke the API key with identifier [[api_key_id]]."""
  return self._request("DELETE", f"/api/api_keys/{api_key_id}")
@

We can verify both the method and, when present, the posted label.
<<test functions>>=
def test_api_key_requests():
  fake_http = FakeHTTPSession([
    FakeResponse(json_data=[{"id": 1}]),
    FakeResponse(json_data={"id": 2, "label": "Exam"}),
    FakeResponse(status_code=204),
  ])
  sa = kthutils.stayawhile.StayawhileSession(
      api_key="token",
      session=fake_http)

  assert sa.list_api_keys() == [{"id": 1}]
  assert sa.create_api_key("Exam") == {"id": 2, "label": "Exam"}
  assert sa.revoke_api_key("2") is None

  assert fake_http.requests[1]["json"] == {"label": "Exam"}
  assert fake_http.requests[2]["method"] == "DELETE"
