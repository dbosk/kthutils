The commands that read tabular data should adapt to their output target.
When we print to a terminal, a clean table is easier to scan.
When we print to a pipe or file, tab-separated CSV is easier to post-process
with standard POSIX tools such as [[cut]].
<<helper functions>>=
def is_tty():
  """Return whether standard output is a terminal."""
  return sys.stdout.isatty()


def value_to_text(value):
  """Return a stable textual representation of [[value]]."""
  if value is None:
    return ""
  if isinstance(value, bool):
    return str(value).lower()
  if isinstance(value, (dict, list)):
    return json.dumps(value)
  return str(value)


def print_csv_rows(rows, fields, headers=None):
  """Print [[rows]] as CSV with the given [[fields]]."""
  writer = csv.writer(sys.stdout, delimiter="\t")
  writer.writerow(headers or fields)
  for row in rows:
    writer.writerow([value_to_text(row.get(field)) for field in fields])


def print_rich_table(rows, fields, headers=None):
  """Print [[rows]] as a clean Rich table."""
  table = Table(box=None, show_edge=False, pad_edge=False)
  for header in headers or fields:
    table.add_column(header)
  for row in rows:
    table.add_row(*[value_to_text(row.get(field)) for field in fields])

  Console(file=sys.stdout).print(table)


def print_records(rows,
                  fields,
                  headers=None,
                  tty=None,
                  today=None,
                  show_ugkthid=False):
  """Print tabular [[rows]] either as Rich output or as CSV."""
  original_fields = list(fields)
  headers = filter_headers(original_fields,
                           headers,
                           show_ugkthid=show_ugkthid)
  fields = visible_fields(original_fields, show_ugkthid=show_ugkthid)
  rows = [format_output_data(row,
                             today=today,
                             show_ugkthid=show_ugkthid)
          for row in rows]
  if tty is None:
    tty = is_tty()

  if tty:
    print_rich_table(rows, fields, headers=headers)
  else:
    print_csv_rows(rows, fields, headers=headers)
@

Commands that return non-tabular data still use formatted JSON.
<<helper functions>>=
TIMESTAMP_FIELDS = {
  "created",
  "ended_at",
  "expires",
  "help_started_at",
  "joined_at",
  "slot_time",
  "started_at",
  "time",
}

DURATION_FIELDS = {
  "duration_secs",
}


def is_ugkthid_field(field):
  """Return whether [[field]] is a [[ugkthid]] field."""
  return "ugkthid" in field


def visible_fields(fields, *, show_ugkthid=False):
  """Return the fields that should be shown."""
  if show_ugkthid:
    return list(fields)
  return [field for field in fields if not is_ugkthid_field(field)]


def filter_headers(fields, headers, *, show_ugkthid=False):
  """Return headers filtered in the same way as [[fields]]."""
  if headers is None:
    return None

  return [header for field, header in zip(fields, headers)
          if show_ugkthid or not is_ugkthid_field(field)]


def print_json(data, *, today=None, show_ugkthid=False):
  """Print [[data]] as formatted JSON."""
  print(json.dumps(format_output_data(data,
                                      today=today,
                                      show_ugkthid=show_ugkthid),
                   indent=2))


def parse_timestamp(timestamp):
  """Return [[timestamp]] as a [[datetime]], when possible."""
  if not timestamp:
    return None

  return datetime.datetime.fromisoformat(
      timestamp.replace("Z", "+00:00"))


def format_timestamp(timestamp, *, today=None):
  """Format [[timestamp]] compactly for CLI output."""
  parsed = parse_timestamp(timestamp)
  if parsed is None:
    return ""

  if today is None:
    today = datetime.date.today()

  if parsed.date() == today:
    return parsed.strftime("%H:%M")
  return parsed.strftime("%Y-%m-%d %H:%M")


def format_duration(duration_secs):
  """Return [[duration_secs]] in a compact human-readable form."""
  if duration_secs in (None, ""):
    return ""

  total_seconds = int(duration_secs)
  hours, remainder = divmod(total_seconds, 3600)
  minutes, seconds = divmod(remainder, 60)
  parts = []

  if hours:
    parts.append(f"{hours}h")
  if minutes:
    if hours:
      parts.append(f"{minutes:02d}m")
    else:
      parts.append(f"{minutes}m")
  if seconds or not parts:
    if hours or minutes:
      parts.append(f"{seconds:02d}s")
    else:
      parts.append(f"{seconds}s")

  return " ".join(parts)


def format_field_value(field, value, *, today=None):
  """Return [[value]] formatted for [[field]]."""
  if field in TIMESTAMP_FIELDS:
    return format_timestamp(value, today=today)
  if field in DURATION_FIELDS:
    return format_duration(value)
  return value


def format_output_data(data, *, today=None, show_ugkthid=False):
  """Return formatted Stay A While output data."""
  if isinstance(data, list):
    return [format_output_data(item,
                               today=today,
                               show_ugkthid=show_ugkthid)
            for item in data]

  if isinstance(data, dict):
    formatted = {}
    for key, value in data.items():
      if not show_ugkthid and is_ugkthid_field(key):
        continue

      if isinstance(value, (dict, list)):
        formatted[key] = format_output_data(value,
                                            today=today,
                                            show_ugkthid=show_ugkthid)
      else:
        formatted[key] = format_field_value(key, value, today=today)
    return formatted

  return data
