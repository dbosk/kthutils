@bookings_cli.command(name="upsert")
def cli_upsert_bookings(queue: Annotated[str, queue_arg],
                        source: Annotated[str, bookings_source_arg]):
  """Upload bookings from a JSON document."""
  session = get_session()
  bookings = load_json_input(source)
  result = session.upsert_bookings(queue, bookings)
  if result is None:
    result = {"queue": queue, "uploaded": len(bookings)}
