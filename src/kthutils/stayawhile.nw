def test_cli_lists_api_keys(monkeypatch):
  fake = FakeStayawhileSession()
  monkeypatch.setattr(kthutils.stayawhile, "get_session", lambda: fake)

  result = runner.invoke(kthutils.stayawhile.cli, ["api-keys", "ls"])

  assert result.exit_code == 0
  assert parse_csv_output(result.stdout) == [
    ["id", "label", "created", "expires"],
    ["1", "X1", "", ""],
  ]
  assert fake.calls == [("list_api_keys",)]


def test_cli_upserts_bookings(monkeypatch, tmp_path):
  fake = FakeStayawhileSession()
  monkeypatch.setattr(kthutils.stayawhile, "get_session", lambda: fake)
  bookings_file = tmp_path / "bookings.json"
  bookings_file.write_text(
      '[{"ugkthid": "u1abc123", "slot_time": "2026-03-01T10:00:00Z"}]')

  result = runner.invoke(
      kthutils.stayawhile.cli,
      ["bookings", "upsert", "Queue", str(bookings_file)])

  assert result.exit_code == 0
  assert fake.calls == [(
    "upsert_bookings",
    "Queue",
    [{"ugkthid": "u1abc123", "slot_time": "2026-03-01T10:00:00Z"}],
  )]
  assert json.loads(result.stdout) == {"updated": 1}


