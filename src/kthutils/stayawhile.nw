@

Every API endpoint requires an [[Authorization: Token]] header, but
the token source differs: queue endpoints use the long-lived API key
(managed by the user), while the API-key management endpoints use the
session JWT from the OAuth2 login.
The [[use_api_key]] flag therefore only decides which authentication
source to ask for.
Queue endpoints use the configured API key directly.
Management endpoints ask the [[StayawhileLogin]] handler for the
current session-token header; the handler also owns refresh-on-403.
<<[[StayawhileSession]] methods>>=
def _request(self,
             method,
             path,
             *,
             params=None,
             payload=None,
             use_api_key=False):
  headers = None
  if use_api_key:
    headers = {"Authorization": f"Token {self.require_api_key()}"}
  elif self.__auth_handler is not None:
    headers = self.__auth_handler.authorization_headers(self.__session)

  response = self.__session.request(
      method,
      f"{self.base_url}{path}",
      headers=headers,
      params=params,
      json=payload)

  response.raise_for_status()

  if response.status_code == 204:
    return None

  try:
    return response.json()
  except ValueError:
    return response.text


def require_api_key(self):
  """Return the configured API key or raise a helpful error."""
  if self.api_key is None:
    self.api_key = get_api_key()
  return self.api_key
