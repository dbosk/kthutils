def test_print_records_uses_csv_when_not_tty(capsys):
  kthutils.stayawhile.print_records(
      [{"id": 1, "label": "X1"}],
      ["id", "label"],
      tty=False)

  assert capsys.readouterr().out == "id\tlabel\r\n1\tX1\r\n"


def test_print_records_uses_clean_rich_table(capsys):
  kthutils.stayawhile.print_records(
      [{"id": 1, "label": "X1"}],
      ["id", "label"],
      tty=True)

  output = capsys.readouterr().out
  assert "id" in output
  assert "X1" in output
  assert "\u2500" not in output


