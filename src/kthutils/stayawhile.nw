The API paths contain queue names as path segments.
The documentation explicitly requires URL encoding for names with spaces or
parentheses, so we apply that in one place.
<<[[StayawhileSession]] methods>>=
def _queue_path(self, queue, suffix):
  encoded_queue = urllib.parse.quote(queue, safe="")
  return f"/api/queues/{encoded_queue}/{suffix}"
<<imports>>=
import urllib.parse
@

The request helper keeps the public methods small and uniform.
It returns parsed JSON when possible and otherwise falls back to plain text.
<<[[StayawhileSession]] methods>>=
def _request(self, method, path, *, params=None, payload=None):
  response = self.__session.request(
      method,
      f"{self.base_url}{path}",
      headers={"Authorization": f"Token {self.api_key}"},
      params=params,
      json=payload)
  response.raise_for_status()

  if response.status_code == 204:
    return None

  try:
    return response.json()
  except ValueError:
    return response.text
@

Let's verify both the queue encoding and the shared authentication header.
<<test helpers>>=
class FakeResponse:
  def __init__(self,
               *,
               json_data=None,
               text="",
               status_code=200):
    self._json_data = json_data
    self.text = text
    self.status_code = status_code

  def raise_for_status(self):
    if self.status_code >= 400:
      raise RuntimeError(f"HTTP {self.status_code}")

  def json(self):
    if self._json_data is None:
      raise ValueError()
    return self._json_data


class FakeHTTPSession:
  def __init__(self, responses=None):
    self.responses = list(responses or [FakeResponse(json_data={})])
    self.requests = []

  def request(self,
              method,
              url,
              *,
              headers=None,
              params=None,
              json=None):
    self.requests.append({
      "method": method,
      "url": url,
      "headers": headers,
      "params": params,
      "json": json,
    })
    return self.responses.pop(0)
