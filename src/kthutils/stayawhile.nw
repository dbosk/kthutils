\section{Logs and help history}

The API provides two teacher-facing logs and one student-facing help-history
endpoint.
The log endpoints share the same optional date-range filtering, while the
interaction log also accepts a type filter.
<<[[StayawhileSession]] methods>>=
def get_interaction_log(self,
                        queue,
                        from_date=None,
                        until=None,
                        interaction_type=None):
  """Return interaction log entries for [[queue]]."""
  params = {}
  if from_date is not None:
    params["from"] = from_date
  if until is not None:
    params["until"] = until
  if interaction_type is not None:
    params["type"] = interaction_type

  return self._request("GET",
                       self._queue_path(queue, "interaction_log"),
                       params=params,
                       use_api_key=True)


def get_queue_log(self, queue, from_date=None, until=None):
  """Return queue log entries for [[queue]]."""
  params = {}
  if from_date is not None:
    params["from"] = from_date
  if until is not None:
    params["until"] = until

  return self._request("GET",
                       self._queue_path(queue, "queue_log"),
                       params=params,
                       use_api_key=True)


def get_my_help_history(self):
  """Return the caller's help history."""
  return self._request("GET", "/api/my_help_history", use_api_key=True)
@

The queue log tells us who is still in the queue, but not whether a help entry
is currently being helped or is still waiting.
To answer that, we combine the active queue reconstructed from [[queue_log]]
with the currently active interactions from [[interaction_log]].
<<helper functions>>=
def queue_entry_key(entry):
  """Return a stable identity key for one queue-log [[entry]]."""
  ugkthid = entry.get("ugkthid")
  if ugkthid:
    return ("ugkthid", ugkthid)

  username = entry.get("username")
  if username:
    return ("username", username)

  raise ValueError(f"queue log entry lacks identity: {entry!r}")


def reconstruct_active_queue_entries(queue_log):
  """Return the active queue entries reconstructed from [[queue_log]]."""
  active = {}
  ordered_log = sorted(enumerate(queue_log),
                       key=lambda pair: (pair[1].get("time", ""), pair[0]))

  for event_index, entry in ordered_log:
    key = queue_entry_key(entry)
    if entry.get("left_queue"):
      active.pop(key, None)
      continue

    current = dict(entry)
    current["_event_index"] = event_index
    active[key] = current

  return sorted(active.values(),
                key=lambda entry: (entry.get("time", ""),
                                   entry.get("_event_index", 0)))


def interaction_entry_key(entry):
  """Return a stable identity key for one interaction-log [[entry]]."""
  ugkthid = entry.get("student_ugkthid")
  if ugkthid:
    return ("ugkthid", ugkthid)

  username = entry.get("student_username")
  if username:
    return ("username", username)

  raise ValueError(f"interaction log entry lacks identity: {entry!r}")


def interaction_is_active(entry):
  """Return whether an interaction-log [[entry]] is still active."""
  ended_at = entry.get("ended_at")
  return ended_at in (None, "")


def collect_active_interactions(interaction_log):
  """Return active interactions keyed by student identity."""
  active = {}
  warnings = []
  ordered_log = sorted(enumerate(interaction_log),
                       key=lambda pair: (pair[1].get("started_at", ""),
                                         pair[0]))
  for event_index, entry in ordered_log:
    if not interaction_is_active(entry):
      continue

    key = interaction_entry_key(entry)
    current = dict(entry)
    current["_event_index"] = event_index
    if key in active:
      warnings.append(
          f"multiple active interactions found for {key[1]}; using latest")
    active[key] = current

  return active, warnings


def reconstruct_current_queue(queue_log, interaction_log):
  """Return the current queue view from both logs."""
  active_queue = reconstruct_active_queue_entries(queue_log)
  active_interactions, warnings = collect_active_interactions(interaction_log)
  view = []
  waiting_position = 0
  matched_interactions = set()
  for entry in active_queue:
    key = queue_entry_key(entry)
    interaction = active_interactions.get(key)
    entry_type = "help" if entry.get("help") else "present"
    if interaction is not None:
      matched_interactions.add(key)
      status = "being_helped"
      helper_name = interaction.get("helper_name")
      help_started_at = interaction.get("started_at")
      waiting_slot = ""
    elif entry_type == "help":
      status = "waiting"
      helper_name = ""
      help_started_at = ""
      waiting_position += 1
      waiting_slot = waiting_position
    else:
      status = "present"
      helper_name = ""
      help_started_at = ""
      waiting_slot = ""

    row = {
      "waiting_position": waiting_slot,
      "realname": entry.get("realname"),
      "username": entry.get("username"),
      "ugkthid": entry.get("ugkthid"),
      "entry_type": entry_type,
      "joined_at": entry.get("time"),
      "helper_name": helper_name,
      "help_started_at": help_started_at,
    }
    view.append(row)

  for key, interaction in active_interactions.items():
    if key not in matched_interactions:
      warnings.append(
          f"active interaction for {key[1]} has no matching queue entry")

  return view, warnings


def queue_view_warnings(queue_log, view, warnings=None):
  """Return warnings when reconstructed queue counts look inconsistent."""
  warnings = list(warnings or [])
  if not queue_log:
    return warnings

  last_entry = max(enumerate(queue_log),
                   key=lambda pair: (pair[1].get("time", ""), pair[0]))[1]
  actual_queue_length = len(view)
  expected_queue_length = last_entry.get("queue_length")
  if expected_queue_length is not None and actual_queue_length != expected_queue_length:
    warnings.append(
        f"reconstructed queue has {actual_queue_length} active entries, "
        f"but latest queue_length is {expected_queue_length}")

  actual_help_amount = sum(1 for entry in view
                           if entry.get("entry_type") == "help")
  expected_help_amount = last_entry.get("help_amount")
  if expected_help_amount is not None and actual_help_amount != expected_help_amount:
    warnings.append(
        f"reconstructed queue has {actual_help_amount} help entries, "
        f"but latest help_amount is {expected_help_amount}")

  actual_present_amount = sum(1 for entry in view
                              if entry.get("entry_type") == "present")
  expected_present_amount = last_entry.get("present_amount")
  if (expected_present_amount is not None
      and actual_present_amount != expected_present_amount):
    warnings.append(
        f"reconstructed queue has {actual_present_amount} present entries, "
        f"but latest present_amount is {expected_present_amount}")

  return warnings


def print_warnings(warnings):
  """Print reconstruction warnings to standard error."""
  for warning in warnings:
    print(f"warning: {warning}", file=sys.stderr)
