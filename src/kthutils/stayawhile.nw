\section{Bookings}

Teachers can list, upload, and clear bookings for a queue, while any user can
inspect their own booking.
<<[[StayawhileSession]] methods>>=
def list_bookings(self, queue):
  """Return the bookings for [[queue]]."""
  return self._request("GET",
                       self._queue_path(queue, "bookings"),
                       use_api_key=True)


def upsert_bookings(self, queue, bookings):
  """Upload or update [[bookings]] for [[queue]]."""
  return self._request("POST",
                       self._queue_path(queue, "bookings"),
                       payload=bookings,
                       use_api_key=True)


def clear_bookings(self, queue):
  """Delete all bookings for [[queue]]."""
  return self._request("DELETE",
                       self._queue_path(queue, "bookings"),
                       use_api_key=True)


def get_my_booking(self, queue):
  """Return the caller's booking for [[queue]]."""
  return self._request("GET",
                       self._queue_path(queue, "my_booking"),
                       use_api_key=True)
