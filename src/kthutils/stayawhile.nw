def list_assistants(self, queue):
  """Return the assistants for [[queue]]."""
  return self._request("GET",
                       self._queue_path(queue, "assistants"),
                       use_api_key=True)


def add_assistant(self, queue, username):
  """Add [[username]] as assistant for [[queue]]."""
  return self._request("POST",
                       self._queue_path(queue, "assistants"),
                       payload={"username": username},
                       use_api_key=True)


def remove_assistant(self, queue, username):
  """Remove [[username]] as assistant for [[queue]]."""
  return self._request(
      "DELETE",
      self._queue_path(queue, f"assistants/{urllib.parse.quote(username)}"),
      use_api_key=True)
