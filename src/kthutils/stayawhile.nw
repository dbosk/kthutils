@api_keys_cli.command(name="rm")
def cli_revoke_api_key(api_key_id: Annotated[str, api_key_id_arg]):
  """Revoke one API key."""
  session = get_session()
  session.revoke_api_key(api_key_id)
  print_json({"revoked": api_key_id})


@bookings_cli.command(name="ls")
def cli_list_bookings(queue: Annotated[str, queue_arg],
                      show_ugkthid: Annotated[bool, show_ugkthid_opt] = False):
  """List bookings for one queue."""
  print_records(get_session().list_bookings(queue),
                BOOKING_FIELDS,
