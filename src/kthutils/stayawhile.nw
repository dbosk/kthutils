\section{API keys}

The API lets users manage their own API keys.
Those endpoints authenticate with the OAuth2 session token rather than
the long-lived API key.
Calling [[_request]] without [[use_api_key]] asks the auth handler for
the current JWT-backed [[Authorization]] header.
<<[[StayawhileSession]] methods>>=
def list_api_keys(self):
  """Return the caller's API keys."""
  return self._request("GET", "/api/api_keys")


def create_api_key(self, label=None):
  """Create a new API key."""
  if label is None:
    return self._request("POST", "/api/api_keys")
  return self._request("POST", "/api/api_keys",
                       payload={"label": label})


def revoke_api_key(self, api_key_id):
  """Revoke the API key with identifier [[api_key_id]]."""
  return self._request("DELETE", f"/api/api_keys/{api_key_id}")
@

The API-key management endpoints use the session token, not the
long-lived API key.
The client therefore delegates header construction to the auth handler,
and we only need to verify that those headers are forwarded.
We also check the posted label for the create call.
<<test functions>>=
def test_api_key_requests():
  class FakeAuthHandler:
    def __init__(self):
      self.calls = 0

    def authorization_headers(self, session, headers=None, refresh=False):
      self.calls += 1
      merged_headers = dict(headers or {})
      merged_headers["Authorization"] = "Token session-jwt"
      return merged_headers

    def __eq__(self, other):
      return type(self) is type(other)

  class FakeUGlogin:
    def __init__(self, username, password, login_trigger_url):
      self.username = username
      self.password = password
      self.login_trigger_url = login_trigger_url

    def __eq__(self, other):
      return (type(self) is type(other)
              and self.username == other.username
              and self.password == other.password
              and self.login_trigger_url == other.login_trigger_url)

  fake_http = FakeHTTPSession([
    FakeResponse(json_data=[{"id": 1}]),
    FakeResponse(json_data={"id": 2, "label": "Exam"}),
    FakeResponse(status_code=204),
  ])
  auth_handler = FakeAuthHandler()
  uglogin_handler = FakeUGlogin("alice", "secret",
                                "https://queue.eecs.kth.se/login")
  sa = kthutils.stayawhile.StayawhileSession(
      api_key="token",
      session=fake_http,
      uglogin_handler=uglogin_handler,
      auth_handler=auth_handler)

  assert sa.list_api_keys() == [{"id": 1}]
  assert sa.create_api_key("Exam") == {"id": 2, "label": "Exam"}
  assert sa.revoke_api_key("2") is None

  session_auth = {"Authorization": "Token session-jwt"}
  assert auth_handler.calls == 3
  assert fake_http.requests[0]["headers"] == session_auth
  assert fake_http.requests[1]["json"] == {"label": "Exam"}
  assert fake_http.requests[1]["headers"] == session_auth
  assert fake_http.requests[2]["method"] == "DELETE"
  assert fake_http.requests[2]["headers"] == session_auth
